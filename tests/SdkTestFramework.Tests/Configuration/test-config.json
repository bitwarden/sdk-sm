{
  "testFramework": {
    "name": "SDK Test Framework POC",
    "version": "1.0.0"
  },
  "configuration": {
    "TEST_MODE": "fake-server",
    "BUILD_SDK": true,
    "AUTO_START_FAKE_SERVER": true,
    "FAKE_SERVER_PORT": 4000,
    "PYTHON_VERSION": "3.13",
    "ENABLED_LANGUAGES": ["python", "go"]
  },
  "timeouts": {
    "DEFAULT_TIMEOUT_MS": 300000,
    "BUILD_TIMEOUT_MS": 300000,
    "TOOL_CHECK_TIMEOUT_MS": 5000,
    "PIP_INSTALL_TIMEOUT_MS": 120000,
    "HTTP_CHECK_TIMEOUT_MS": 2000,
    "SERVER_STARTUP_DELAY_MS": 2000,
    "PROCESS_EXIT_WAIT_MS": 5000
  },
  "retries": {
    "RETRY_ATTEMPTS": 2,
    "RETRY_DELAY_MS": 1000
  }
}
