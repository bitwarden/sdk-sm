# SDK Test Framework Environment Variables
# Copy this file to .env and fill in your values

# ========================================
# REQUIRED - Test scripts will fail without these
# ========================================

# Authentication (Required)
# IMPORTANT: When TEST_MODE=fake-server in test-config.json, you MUST use these exact test credentials
# For fake server: Use the test credentials below (required for fake-server to accept requests)
# For real server: Replace with your actual access token
ACCESS_TOKEN=0.ec2c1d46-6a4b-4751-a310-af9601317f2d.C2IgxjjLF7qSshsbwe8JGcbM075YXw:X8vbvA0bduihIDe/qrzIQQ==

# Organization ID (Required)
# IMPORTANT: When TEST_MODE=fake-server in test-config.json, you MUST use this exact test organization ID
# For fake server: Use the test organization ID below (required for fake-server to accept requests)
# For real server: Replace with your actual organization ID
ORGANIZATION_ID=f4e44a7f-1190-432a-9d4a-af96013127cb

# API URLs (Required)
# IMPORTANT: These URLs must match your TEST_MODE in test-config.json
# For fake server mode (TEST_MODE=fake-server): Use http://localhost:4000 URLs (must match FAKE_SERVER_PORT)
# For real server mode (TEST_MODE=real-server): Use your actual Bitwarden server URLs
API_URL=http://localhost:4000/api
IDENTITY_URL=http://localhost:4000/identity

# ========================================
# OPTIONAL - Additional configuration options
# ========================================

# Test execution mode (Optional - defaults vary by context)
# Values: "fake-server" or "real-server"
# TEST_MODE=fake-server

# State file path for SDK client caching (Optional)
# Improves performance by caching authentication state
# STATE_FILE=/tmp/bitwarden-sdk-state.json

# ========================================
# OPTIONAL - Test Framework Configuration
# These are only used by the .NET test framework (dotnet test)
# Not needed when running test_suite.py or test_suite.go directly
# ========================================

# Build SDK before testing (Optional - framework only)
# BUILD_SDK=true

# Auto-start fake server (Optional - framework only)
# AUTO_START_FAKE_SERVER=true

# Auto-generate schemas if missing (Optional - framework only)
# Set to true to automatically run 'npm run schemas' if schema files are missing
# Requires npm to be installed. Default is false (fail fast if schemas missing)
# AUTO_GENERATE_SCHEMAS=false

# Fake server port (Optional - framework only)
# FAKE_SERVER_PORT=4000

# Python version preference (Optional - framework only)
# PYTHON_VERSION=3.13

# ========================================
# OPTIONAL - Timeout Configuration (milliseconds)
# Only used by the .NET test framework
# ========================================

# DEFAULT_TIMEOUT_MS=300000
# BUILD_TIMEOUT_MS=300000
# TOOL_CHECK_TIMEOUT_MS=5000
# PIP_INSTALL_TIMEOUT_MS=120000
# HTTP_CHECK_TIMEOUT_MS=2000
# SERVER_STARTUP_DELAY_MS=2000
# PROCESS_EXIT_WAIT_MS=5000