# SDK Test Framework Environment Variables
# Copy this file to .env and fill in your values

# Authentication - Fake Server
# For fake server testing, use these test credentials:
ACCESS_TOKEN=0.ec2c1d46-6a4b-4751-a310-af9601317f2d.C2IgxjjLF7qSshsbwe8JGcbM075YXw:X8vbvA0bduihIDe/qrzIQQ==
ORGANIZATION_ID=f4e44a7f-1190-432a-9d4a-af96013127cb

# Authentication - Real Server (optional)
# For real Bitwarden server testing, provide service account credentials
# These will be used to dynamically generate an access token
BWS_CLIENT_ID=
BWS_CLIENT_SECRET=

# API URLs
# For fake server: API uses http://localhost:4000/api, Identity uses http://localhost:4000/identity
# For real server: Use your actual Bitwarden server URLs
API_URL=http://localhost:4000/api
IDENTITY_URL=http://localhost:4000/identity
